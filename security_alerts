class PacketAnalyzer:
    def __init__(self, interface="wlp2s0", max_packets=1000):
        self.interface = interface
        self.packets = deque(maxlen=max_packets)
        self.start_time = time.time()
        
        # Log file for continuous writing
        self.log_file = open('packet_sniffer.log', 'w')
        self.log_file.write("=" * 80 + "\n")
        self.log_file.write("PACKET SNIFFER - LIVE RAW LOGS\n")
        self.log_file.write(f"Started: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n")
        self.log_file.write("=" * 80 + "\n\n")
        self.log_file.flush()
        
        # Statistics
        self.protocol_counts = Counter()
        self.ip_packet_counts = Counter()
        self.ip_byte_counts = Counter()
        self.domain_counts = Counter()
        self.dns_queries = Counter()
        
        # Recent activity (for display)
        self.recent_packets = deque(maxlen=10)
        
        # Raw logs (for debugging/inspection)
        self.raw_logs = deque(maxlen=50)
        
        # Security alerts
        self.alerts = deque(maxlen=50)
        
        # Security tracking state
        self._port_scan_tracker = defaultdict(set)      # src_ip -> set of dst_ports
        self._port_scan_window = defaultdict(float)     # src_ip -> first seen timestamp
        self._arp_counts = deque(maxlen=200)             # (timestamp,) for ARP flood detection
        self._icmp_counts = deque(maxlen=200)            # (timestamp,) for ICMP flood detection
        self._syn_tracker = defaultdict(list)            # dst_ip -> [timestamps] for SYN flood
        self._alerted_scans = set()                      # IPs already alerted for port scan
        self._alerted_protocols = set()                  # Protocols already alerted as unencrypted
        self._large_packet_threshold = 65535              # Only flag truly abnormal packets
        self._alert_cooldowns = {}                       # (alert_type, key) -> last_alert_timestamp
        self._cooldown_seconds = 60                      # Min seconds between same alert
        self._alerted_connections = set()                 # (type, src, dst) already alerted once
        self.flagged_ips = Counter()                      # IPs flagged with alert count
        
        # Performance metrics
        self.packet_times = deque(maxlen=100)
        self.byte_times = deque(maxlen=100)
        
    def add_packet(self, packet_data):
        """Process incoming packet"""
        try:
            # Store raw JSON for logs panel
            current_time = time.time()
            self.raw_logs.append({
                'time': current_time,
                'data': packet_data
            })
            
            # Write to log file
            timestamp = datetime.fromtimestamp(current_time).strftime('%H:%M:%S.%f')[:-3]
            try:
                parsed = json.loads(packet_data)
                formatted = json.dumps(parsed, indent=2)
                self.log_file.write(f"[{timestamp}]\n{formatted}\n\n")
            except:
                self.log_file.write(f"[{timestamp}]\n{packet_data}\n\n")
            self.log_file.flush()  # Ensure it's written immediately
            
            pkt = json.loads(packet_data)
            self.packets.append(pkt)
            current_time = time.time()
            
            # Update protocol stats
            protocol = pkt.get('protocol', 'Unknown')
            self.protocol_counts[protocol] += 1
            
            # Update IP stats
            src_ip = pkt.get('src_ip', '')
            dst_ip = pkt.get('dst_ip', '')
            pkt_len = pkt.get('length', 0)
            
            if src_ip:
                self.ip_packet_counts[src_ip] += 1
                self.ip_byte_counts[src_ip] += pkt_len
            if dst_ip:
                self.ip_packet_counts[dst_ip] += 1
                self.ip_byte_counts[dst_ip] += pkt_len
            
            # Track domains
            if 'domain' in pkt:
                self.domain_counts[pkt['domain']] += 1
            
            # Track DNS queries
            if 'dns_query' in pkt:
                self.dns_queries[pkt['dns_query']] += 1
            
            # Performance tracking
            self.packet_times.append(current_time)
            self.byte_times.append((current_time, pkt_len))
            
            # Add to recent packets
            self.recent_packets.append(pkt)
            
            # Security alerts
            self._check_security_alerts(pkt)
            
        except json.JSONDecodeError:
            pass
    
    def _flag_ip(self, ip, alert_type):
        """Track an IP that triggered a security alert"""
        if ip:
            self.flagged_ips[ip] += 1

    def _add_alert(self, now, alert_type, msg, involved_ip=None, cooldown_key=None):
        """Add a security alert with optional cooldown to prevent spam"""
        # Rate-limit: skip if same (type, key) fired recently
        if cooldown_key:
            ck = (alert_type, cooldown_key)
            last = self._alert_cooldowns.get(ck, 0)
            if time.time() - last < self._cooldown_seconds:
                return
            self._alert_cooldowns[ck] = time.time()
        self.alerts.append({'time': now, 'type': alert_type, 'msg': msg})
        if involved_ip:
            self._flag_ip(involved_ip, alert_type)

    def _check_security_alerts(self, pkt):
        """Check for suspicious activity"""
        now = datetime.now().strftime('%H:%M:%S')
        ts = time.time()
        protocol = pkt.get('protocol', '')
        src_ip = pkt.get('src_ip', '')
        dst_ip = pkt.get('dst_ip', '')
        src_port = pkt.get('src_port', 0)
        dst_port = pkt.get('dst_port', 0)
        pkt_len = pkt.get('length', 0)

        # 1. DNS tunneling detection (very long domains)
        if 'dns_query' in pkt and len(pkt['dns_query']) > 50:
            query = pkt['dns_query']
            # Skip normal reverse DNS lookups
            if not query.endswith('.in-addr.arpa') and not query.endswith('.ip6.arpa'):
                self._add_alert(now, 'DNS_TUNNEL',
                    f"Suspicious long DNS query: {query[:30]}...", src_ip,
                    cooldown_key=src_ip)

        # 2. Unencrypted protocol alerts (FTP, HTTP, POP3, IMAP, SMTP)
        unencrypted = {'FTP', 'HTTP', 'POP3', 'IMAP', 'SMTP'}
        if protocol in unencrypted and protocol not in self._alerted_protocols:
            self._alerted_protocols.add(protocol)
            self._add_alert(now, 'UNENCRYPTED',
                f"Unencrypted {protocol} traffic detected — credentials may be exposed", src_ip)

        # 3. Port scan detection (single IP hitting many ports on same dest in short window)
        if src_ip and dst_port and dst_ip:
            key = (src_ip, dst_ip)
            if key not in self._port_scan_window:
                self._port_scan_window[key] = ts
            # Reset window after 60 seconds
            if ts - self._port_scan_window[key] > 60:
                self._port_scan_tracker[key] = set()
                self._port_scan_window[key] = ts
            self._port_scan_tracker[key].add(dst_port)
            if len(self._port_scan_tracker[key]) > 15 and key not in self._alerted_scans:
                self._alerted_scans.add(key)
                self._add_alert(now, 'PORT_SCAN',
                    f"Possible port scan from {src_ip} → {dst_ip} ({len(self._port_scan_tracker[key])} ports)", src_ip)

        # 4. ARP flood / ARP spoofing detection
        if protocol == 'ARP':
            self._arp_counts.append(ts)
            # More than 50 ARP packets in 10 seconds
            recent = [t for t in self._arp_counts if ts - t < 10]
            if len(recent) > 50:
                self._add_alert(now, 'ARP_FLOOD',
                    f"ARP flood detected — {len(recent)} ARP packets in 10s (possible spoofing)", src_ip)
                self._arp_counts.clear()

        # 5. ICMP flood detection (ping flood / smurf attack)
        if protocol == 'ICMP' or protocol == 'ICMPv6':
            self._icmp_counts.append(ts)
            recent = [t for t in self._icmp_counts if ts - t < 10]
            if len(recent) > 100:
                self._add_alert(now, 'ICMP_FLOOD',
                    f"ICMP flood detected — {len(recent)} ICMP packets in 10s from {src_ip}", src_ip)
                self._icmp_counts.clear()

        # 6. DNS exfiltration — suspicious subdomain patterns
        if 'dns_query' in pkt:
            query = pkt['dns_query']
            # Skip standard reverse DNS lookups (e.g. 1.2.3.4.in-addr.arpa)
            if not query.endswith('.in-addr.arpa') and not query.endswith('.ip6.arpa'):
                labels = query.split('.')
                # Check for unusually many subdomains (>5 levels)
                if len(labels) > 5:
                    self._add_alert(now, 'DNS_EXFIL',
                        f"Excessive DNS subdomains ({len(labels)} levels): {query[:40]}...", src_ip,
                        cooldown_key=query)
                # Check for long individual labels (base64-encoded data)
                for label in labels:
                    if len(label) > 40:
                        self._add_alert(now, 'DNS_EXFIL',
                            f"Suspicious long DNS label ({len(label)} chars): {label[:25]}...", src_ip,
                            cooldown_key=src_ip)
                        break

        # 7. Unusually large packet (possible data exfiltration or attack)
        if pkt_len > self._large_packet_threshold:
            self._add_alert(now, 'LARGE_PKT',
                f"Unusually large packet ({pkt_len} bytes) {src_ip} → {dst_ip}", src_ip,
                cooldown_key=src_ip)

        # 8. Known malicious / suspicious port usage
        suspicious_ports = {
            4444: 'Metasploit default',
            5555: 'Android debug (ADB)',
            1337: 'Leet/backdoor',
            31337: 'Back Orifice',
            6667: 'IRC (C2 channel)',
            6697: 'IRC over TLS (C2)',
            8443: 'Alt HTTPS',
            9001: 'Tor relay',
            9050: 'Tor SOCKS',
            9150: 'Tor browser',
            12345: 'NetBus trojan',
            27374: 'SubSeven trojan',
        }
        for port in (src_port, dst_port):
            if port in suspicious_ports:
                conn = (src_ip, dst_ip, port)
                if conn not in self._alerted_connections:
                    self._alerted_connections.add(conn)
                    self._add_alert(now, 'SUSPECT_PORT',
                        f"Suspicious port {port} ({suspicious_ports[port]}) — {src_ip} ↔ {dst_ip}", src_ip)
                break

        # 9. Rapid DNS queries to many unique domains (possible DGA malware)
        if 'dns_query' in pkt:
            unique_domains = len(self.dns_queries)
            if unique_domains > 0 and unique_domains % 100 == 0:
                elapsed = ts - self.start_time
                rate = unique_domains / max(elapsed, 1)
                if rate > 2:  # More than 2 unique domains/sec
                    self._add_alert(now, 'DGA_SUSPECT',
                        f"High unique DNS query rate: {unique_domains} domains ({rate:.1f}/sec) — possible DGA", src_ip)

        # 10. Non-standard DNS port (DNS on port other than 53)
        if protocol == 'UDP' and dst_port == 5353:
            pass  # mDNS is normal
        elif protocol in ('TCP', 'UDP') and dst_port != 53 and src_port != 53:
            if 'dns_query' in pkt:
                self._add_alert(now, 'DNS_NON_STD',
                    f"DNS traffic on non-standard port {dst_port} from {src_ip}", src_ip)

        # 11. Database access detection (alerts once per connection pair)
        db_protocols = {'MySQL', 'PostgreSQL'}
        if protocol in db_protocols:
            conn = ('DB', src_ip, dst_ip)
            if conn not in self._alerted_connections:
                self._alerted_connections.add(conn)
                self._add_alert(now, 'DB_ACCESS',
                    f"{protocol} traffic detected ({src_ip}:{src_port} → {dst_ip}:{dst_port})", src_ip)

        # 12. RDP exposure detection (alerts once per connection pair)
        if protocol == 'RDP':
            conn = ('RDP', src_ip, dst_ip)
            if conn not in self._alerted_connections:
                self._alerted_connections.add(conn)
                self._add_alert(now, 'RDP_DETECTED',
                    f"RDP session detected ({src_ip} → {dst_ip}) — verify authorization", src_ip)
    
    def get_pps(self):
        """Calculate packets per second"""
        if len(self.packet_times) < 2:
            return 0
        time_window = self.packet_times[-1] - self.packet_times[0]
        if time_window == 0:
            return 0
        return len(self.packet_times) / time_window
    
    def get_bandwidth(self):
        """Calculate bandwidth (bytes/sec)"""
        if len(self.byte_times) < 2:
            return 0
        recent_bytes = [(t, b) for t, b in self.byte_times if t > time.time() - 1]
        if len(recent_bytes) < 2:
            return 0
        total_bytes = sum(b for _, b in recent_bytes)
        return total_bytes
    
    def format_bytes(self, bytes_val):
        """Format bytes to human readable"""
        for unit in ['B', 'KB', 'MB', 'GB']:
            if bytes_val < 1024:
                return f"{bytes_val:.1f} {unit}"
            bytes_val /= 1024
        return f"{bytes_val:.1f} TB"
    
    def reset(self):
        """Reset all statistics"""
        self.packets.clear()
        self.start_time = time.time()
        self.protocol_counts.clear()
        self.ip_packet_counts.clear()
        self.ip_byte_counts.clear()
        self.domain_counts.clear()
        self.dns_queries.clear()
        self.recent_packets.clear()
        self.raw_logs.clear()
        self.alerts.clear()
        self.packet_times.clear()
        self.byte_times.clear()
        self._port_scan_tracker.clear()
        self._port_scan_window.clear()
        self._arp_counts.clear()
        self._icmp_counts.clear()
        self._syn_tracker.clear()
        self._alerted_scans.clear()
        self._alerted_protocols.clear()
        self._alert_cooldowns.clear()
        self._alerted_connections.clear()
        self.flagged_ips.clear()
        
        # Reset log file
        self.log_file.close()
        self.log_file = open('packet_sniffer.log', 'w')
        self.log_file.write("=" * 80 + "\n")
        self.log_file.write("PACKET SNIFFER - LIVE RAW LOGS (RESET)\n")
        self.log_file.write(f"Reset at: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n")
        self.log_file.write("=" * 80 + "\n\n")
        self.log_file.flush()
    
    def get_formatted_logs(self):
        """Get all logs formatted for display"""
        output = []
        for log in self.raw_logs:
            timestamp = datetime.fromtimestamp(log['time']).strftime('%H:%M:%S.%f')[:-3]
            try:
                parsed = json.loads(log['data'])
                formatted = json.dumps(parsed, indent=2)
                output.append(f"[{timestamp}]\n{formatted}\n")
            except:
                output.append(f"[{timestamp}]\n{log['data']}\n")
        return "\n".join(output)

